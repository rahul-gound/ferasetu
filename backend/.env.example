# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (generate a strong random secret)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Sarvam AI API Keys
# Get your keys from https://sarvam.ai
SARVAM_30B_API_KEY=your_sarvam_30b_api_key_here
SARVAM_105B_API_KEY=your_sarvam_105b_api_key_here
SARVAM_API_BASE_URL=https://api.sarvam.ai/v1

# Database
DATABASE_PATH=./data/fera_shopkeeper.db

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Free tier limits
FREE_TIER_MAX_PRODUCTS=50
FREE_TIER_STORAGE_MB=500

# Domain config
BASE_DOMAIN=fera-shop.fera-seach.tech
