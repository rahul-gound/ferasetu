# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (generate a strong random secret)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Sarvam AI API Keys
# Get your keys from https://sarvam.ai
SARVAM_30B_API_KEY=sk_your_30b_api_key_here
SARVAM_105B_API_KEY=sk_your_105b_api_key_here
SARVAM_API_BASE_URL=https://api.sarvam.ai/v1

# Database
DATABASE_PATH=./data/fera_shopkeeper.db

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Free tier limits
FREE_TIER_MAX_PRODUCTS=50
FREE_TIER_STORAGE_MB=500

# Domain config
BASE_DOMAIN=fera-search.tech

# SMTP Configuration (Maileroo)
# Get SMTP credentials from your Maileroo dashboard
SMTP_HOST=smtp.maileroo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_maileroo_smtp_password_here
EMAIL_FROM="Fera AI <noreply@yourdomain.com>"

# Admin
ADMIN_EMAIL=admin@fera.ai

# Razorpay Payments
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
