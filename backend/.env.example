# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
HOST=127.0.0.1
NODE_ENV=production

# JWT Secret (generate a strong random secret)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Sarvam AI API Keys
# Get your keys from https://sarvam.ai
SARVAM_30B_API_KEY=sk_your_30b_api_key_here
SARVAM_105B_API_KEY=sk_your_105b_api_key_here
SARVAM_API_BASE_URL=https://api.sarvam.ai/v1

# Database
# If MYSQL_HOST, MYSQL_USER, or MYSQL_DATABASE are missing, backend auto-falls back to SQLite.
# If MySQL credentials are present but connection fails, backend also auto-falls back to SQLite.
MYSQL_HOST=your-oracle-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=fera_shopkeeper

# SQLite fallback path
DATABASE_PATH=./data/fera_shopkeeper.db

# Appwrite storage for production files/images
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_backend_only_appwrite_api_key
APPWRITE_PRODUCT_IMAGES_BUCKET_ID=69f60d1f00330c793cab
APPWRITE_SHOP_ASSETS_BUCKET_ID=your_shop_assets_bucket_id

# Local file uploads fallback only
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Frontend URL (for CORS)
FRONTEND_URL=https://fera-search.tech

# Trial and plan limits
TRIAL_DAYS=7
TRIAL_AI_CREDITS=20
EXTRA_STORAGE_PRICE_PER_GB=20

# Domain config
BASE_DOMAIN=fera-search.tech

# SMTP Configuration (Maileroo)
# Get SMTP credentials from your Maileroo dashboard
SMTP_HOST=smtp.maileroo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_maileroo_smtp_password_here
EMAIL_FROM="Fera AI <noreply@yourdomain.com>"

# Admin
ADMIN_EMAIL=admin@fera.ai

# Razorpay Payments
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
